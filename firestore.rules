rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myRole() {
      return myData().role.lower();
    }

    function isAdmin() {
      return userDocExists()
        && (myRole() == 'admin' || myRole() == 'it');
    }

    function isIT() {
      return userDocExists()
        && myRole() == 'it';
    }

    function isAccountant() {
      return userDocExists()
        && myRole() == 'accountant';
    }

    function isEngineer() {
      return userDocExists()
        && myRole() == 'engineer';
    }

    function isNotAccountant() {
      return userDocExists()
        && myRole() != 'accountant';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastLogin', 'knownDevices'])
        );
    }

    match /company/main {
      allow read: if isSignedIn();
      allow write: if isNotAccountant();
    }

    match /company/settings {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /backups/{backupId} {
      allow read, write: if isAdmin();
    }

    match /activity/{entryId} {
      allow read: if isAdmin();
      allow create: if isNotAccountant()
        || request.resource.data.by == 'النظام';
      allow update, delete: if false;
    }

    match /loginLockouts/{email} {
      allow read, write: if true;
    }
  }
}
